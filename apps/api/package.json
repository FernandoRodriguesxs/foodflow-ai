{
  "name": "@foodflow/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build && tsc-alias",
    "start": "node -r tsconfig-paths/register dist/main.js",
    "lint": "echo 'no linter configured yet'",
    "test": "jest --passWithNoTests",
    "db:test": "npx tsx src/database/test-connection.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@foodflow/shared": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-fastify": "^11.1.0",
    "better-auth": "^1.5.6",
    "bullmq": "^5.71.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/testing": "^11.1.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
